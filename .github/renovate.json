{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main-source"
  ],
  "prHourlyLimit": 2,
  "enabledManagers": [
    "github-actions"
  ],
  "ignorePaths": [
    "charts/**",
    "assets/**",
    "packages/**"
  ]
}
